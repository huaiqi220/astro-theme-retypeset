---
import type { ThemeConfig } from '@/types'
import { themeConfig } from '@/config'
import { isPostPage } from '@/utils/page'

type DateFormat = ThemeConfig['global']['dateFormat']

interface Props {
  date: Date
  updatedDate?: Date
  minutes: number
  time?: string
}

const { date, updatedDate, minutes, time } = Astro.props
const { dateFormat: format } = themeConfig.global
const isPost = isPostPage(Astro.url.pathname)
const timeSpacingClass = isPost ? 'ml-1.75' : 'ml-1.5'

function formatDate(date: Date, format: DateFormat) {
  if (format === 'YYYY-MM-DD') {
    return date.toISOString().split('T')[0]
  }

  const options: Intl.DateTimeFormatOptions = {
    year: 'numeric',
    month: format === 'MMM D YYYY' || format === 'D MMM YYYY' ? 'short' : '2-digit',
    day: format === 'MMM D YYYY' || format === 'D MMM YYYY' ? 'numeric' : '2-digit',
  }

  switch (format) {
    // US date format: 04-13-2025
    case 'MM-DD-YYYY':
      return date.toLocaleDateString('en-US', options).replace(/\//g, '-')

    // European date format: 13-04-2025
    case 'DD-MM-YYYY':
      return date.toLocaleDateString('en-GB', options).replace(/\//g, '-')

    // US month text format: Apr 13 2025
    case 'MMM D YYYY':
      return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).replace(',', '')

    // British month text format: 13 Apr 2025
    case 'D MMM YYYY':
      return date.toLocaleDateString('en-GB', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).replace(',', '')

    // Default to ISO format
    default:
      return date.toISOString().split('T')[0]
  }
}

function parseTime(rawTime: string) {
  const normalized = rawTime.trim().replace('：', ':')

  let match = normalized.match(/^(\d{1,2})\s*:\s*(\d{1,2})$/)
  if (!match) {
    match = normalized.match(/^(\d{1,2})\s*[点时]\s*(\d{1,2})\s*分?$/)
  }
  if (!match) {
    return null
  }

  const hour = Number(match[1])
  const minute = Number(match[2])

  if (Number.isNaN(hour) || Number.isNaN(minute) || hour < 0 || hour > 23 || minute < 0 || minute > 59) {
    return null
  }

  return { hour, minute }
}

function getChineseTimePeriod(hour: number) {
  if (hour < 5) {
    return '凌晨'
  }
  if (hour < 11) {
    return '上午'
  }
  if (hour < 13) {
    return '中午'
  }
  if (hour < 18) {
    return '下午'
  }
  if (hour < 20) {
    return '傍晚'
  }
  return '深夜'
}

function formatChineseTime(rawTime: string) {
  const parsed = parseTime(rawTime)
  if (!parsed) {
    return rawTime
  }

  const period = getChineseTimePeriod(parsed.hour)
  const displayHour = parsed.hour % 12 || 12
  const displayMinute = parsed.minute.toString().padStart(2, '0')
  return `${period}${displayHour}时${displayMinute}分`
}
---

<!-- published date -->
<time datetime={date.toISOString().split('T')[0]}>
  {formatDate(date, format)}
</time>

<!-- updated date -->
{updatedDate && (
  <time
    datetime={updatedDate.toISOString().split('T')[0]}
    class={timeSpacingClass}
  >
    updated {formatDate(updatedDate, format)}
  </time>
)}

<!-- custom time -->
{time && (
  <span class:list={[timeSpacingClass, 'not-italic']}>
    {formatChineseTime(time)}
  </span>
)}

<!-- reading time -->
<span class={timeSpacingClass}>
  {minutes} min
</span>
